rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Client SDK access to push token docs is intentionally blocked.
    // This collection is managed by server code via firebase-admin.
    match /fcmTokens/{tokenId} {
      allow read: if false;
      allow create, update: if false;
      allow delete: if false;
    }

    // Default deny for every other document path.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
